# mqo-demo configuration — copy to .env and fill in. NEVER commit .env.
#
# Required: your Anthropic API key (the demo drives Claude through mqo-mcp).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
#
# AtScale OIDC client secret for the mcp-aws cluster (defaults to "atscale" if unset).
ATSCALE_OIDC_SECRET=atscale
#
# PGWire (SQL backend) credentials — required for SQL-path queries.
# The mcp-aws cluster rejects the OIDC bearer token for PGWire; use your
# AtScale username and password here instead.  Note: if your password contains
# special characters (& < > etc.) they do NOT need quoting in this file —
# the shell reads .env values verbatim.
ATSCALE_PG_USER=REPLACE_ME
ATSCALE_PG_PASSWORD=REPLACE_ME
#
# Optional: override the Anthropic model (defaults in app.py).
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# Optional: redirect to a different AtScale cluster.
# ATSCALE_ENDPOINT=mcp-aws.atscaleinternal.com:15432
# ATSCALE_XMLA_URL=https://mcp-aws.atscaleinternal.com/v1/xmla
# ATSCALE_OIDC_TOKEN_URL=https://mcp-aws.atscaleinternal.com/auth/realms/atscale/protocol/openid-connect/token
# ATSCALE_MODEL=tpcds_benchmark_model
