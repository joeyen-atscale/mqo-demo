# mqo-demo configuration — copy to .env and fill in. NEVER commit .env.
#
# Required: your Anthropic API key (the demo drives Claude through mqo-mcp).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
#
# AtScale OIDC client secret for the mcp-aws cluster (defaults to "atscale" if unset).
ATSCALE_OIDC_SECRET=atscale
#
# Optional: override the Anthropic model (defaults in app.py).
# ANTHROPIC_MODEL=claude-sonnet-4-6
